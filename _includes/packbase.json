{%- include packages-assign.html -%}
{%- assign install_cmd_template = site.suggested_command | default: "install {package}" -%}
{
  "filename": "packbase.json",
  "manifest": "https://yafb.net/s/packbase-v1.schema.json",
  "protocol": "v1",
  "packages": [
{%- assign _first = true -%}
{%- for pkg in packages -%}
  {%- if pkg.title -%}
    {%- unless pkg.excluded_in_search or pkg.unsafe -%}
      {%- assign repository_url = pkg.repository | default: "" | append: "" | strip -%}
      {%- assign repository_path = pkg.repository_path | default: "" | append: "" | strip -%}
      {%- assign repository_path = repository_path | remove_first: "/" | remove_first: "./" | replace: "//", "/" -%}
      {%- assign github_repo_base = repository_url | remove: ".git" | replace: "http://github.com/", "https://github.com/" | replace: "https://www.github.com/", "https://github.com/" | replace: "http://www.github.com/", "https://github.com/" -%}
      {%- unless github_repo_base contains "https://github.com/" -%}
        {%- assign github_repo_base = "" -%}
      {%- endunless -%}
      {%- assign repository_default_ref = "main" -%}
      {%- if pkg.versions contains "main" -%}
        {%- assign repository_default_ref = "main" -%}
      {%- elsif pkg.versions contains "master" -%}
        {%- assign repository_default_ref = "master" -%}
      {%- endif -%}
      {%- assign github_repo_slug = github_repo_base | remove: "https://github.com/" -%}
      {%- assign github_repo_owner = github_repo_slug | split: "/" | first -%}
      {%- assign github_repo_name = github_repo_slug | split: "/" | last -%}
      {%- assign repository_tree_base = github_repo_base | append: "/tree/" | append: repository_default_ref -%}
      {%- if repository_path != "" and github_repo_base != "" -%}
        {%- assign repository_page_url = repository_tree_base | append: "/" | append: repository_path -%}
      {%- else -%}
        {%- assign repository_page_url = repository_url -%}
      {%- endif -%}
      {%- assign author_name = pkg.author | default: "" | append: "" | strip -%}
      {%- assign author_github = pkg.author_github | default: "" | append: "" | strip -%}
      {%- assign author_url = pkg.author_url | default: "" | append: "" | strip -%}
      {%- assign packager_name = pkg.packager | default: "" | append: "" | strip -%}
      {%- assign packager_github = pkg.packager_github | default: "" | append: "" | strip -%}
      {%- assign packager_url = pkg.packager_url | default: "" | append: "" | strip -%}
      {%- assign author_github_url = "" -%}
      {%- if author_github != "" -%}
        {%- assign author_github_url = "https://github.com/" | append: author_github -%}
      {%- endif -%}
      {%- assign packager_github_url = "" -%}
      {%- if packager_github != "" -%}
        {%- assign packager_github_url = "https://github.com/" | append: packager_github -%}
      {%- endif -%}
      {%- assign install_command = install_cmd_template | replace: "{package}", pkg.title -%}
      {%- assign package_language = pkg.package_language | default: site.default_package_language | default: "shell" | append: "" | strip | downcase -%}
      {%- if package_language == "" -%}
        {%- assign package_language = "shell" -%}
      {%- endif -%}
      {%- assign package_format = pkg.package_format | default: site.default_package_format | default: "source" | append: "" | strip | downcase | slugify -%}
      {%- if package_format == "" -%}
        {%- assign package_format = "source" -%}
      {%- endif -%}
      {%- assign updated_at_value = "1970-01-01T00:00:00+00:00" -%}
      {%- if pkg.updated_at -%}
        {%- assign now_ts = "now" | date: "%s" | plus: 0 -%}
        {%- assign pkg_updated_ts = pkg.updated_at | date: "%s" | plus: 0 -%}
        {%- if pkg_updated_ts > 0 and pkg_updated_ts <= now_ts -%}
          {%- assign updated_at_value = pkg.updated_at | date: "%Y-%m-%dT%H:%M:%S+00:00" -%}
        {%- endif -%}
      {%- endif -%}
      {%- unless _first -%},
{%- endunless -%}
      {%- assign _first = false -%}
      {%- assign package_url = site.url | default: "" -%}
      {%- if pkg.url != "" -%}
        {%- assign _url_is_absolute = pkg.url | slice: 0, 4 | downcase -%}
        {%- if _url_is_absolute == "http" -%}
          {%- assign package_url = pkg.url -%}
        {%- else -%}
          {%- assign site_url = site.url | default: "" -%}
          {%- if site_url != "" -%}
            {%- assign site_url = site_url | rstrip -%}
            {%- assign leading_slash = pkg.url | slice: 0 -%}
            {%- if leading_slash == "/" -%}
              {%- assign package_url = site_url | append: pkg.url -%}
            {%- else -%}
              {%- assign package_url = site_url | append: "/" | append: pkg.url -%}
            {%- endif -%}
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}
    {%- assign package_version = pkg.version | default: "" | strip -%}
      {%- if package_version == "" or package_version == nil -%}
        {%- assign package_version = "0.0.0" -%}
      {%- endif -%}
    {%- assign package_license = pkg.license | default: "" | strip -%}
      {%- if package_license == "" or package_license == nil -%}
        {%- assign package_license = "UNLICENSED" -%}
      {%- endif -%}
      {%- assign package_homepage = pkg.homepage | default: "" | strip -%}
      {%- if package_homepage == "" or package_homepage == nil -%}
        {%- assign package_homepage = package_url -%}
      {%- endif -%}
      {%- assign package_dependencies = pkg.dependencies -%}
      {%- if package_dependencies == nil -%}
        {%- assign package_dependencies = "" | split: "" -%}
      {%- endif -%}
      {%- assign package_versions = pkg.versions -%}
      {%- if package_versions == nil -%}
        {%- assign package_versions = "" | split: "" -%}
      {%- endif -%}
    {
      "name": {{ pkg.title | jsonify }},
      "description": {{ pkg.description | jsonify }},
      "url": {{ package_url | jsonify }},
      "updated_at": {{ updated_at_value | jsonify }},
      "version": {{ package_version | jsonify }},
      "language": {{ package_language | jsonify }},
      "format": {{ package_format | jsonify }},
      "license": {{ package_license | jsonify }},
      "keywords": {{ pkg.keywords | jsonify }},
      "categories": {{ pkg.categories | jsonify }},
      "dependencies": {{ package_dependencies | jsonify }},
      "versions": {{ package_versions | jsonify }},
      "install": {{ install_command | jsonify }},
      "homepage": {{ package_homepage | jsonify }},
      "repository": {
        "url": {{ repository_url | jsonify }},
        "path": {{ repository_path | jsonify }},
        "default_ref": {{ repository_default_ref | jsonify }},
        "browse_url": {{ repository_page_url | jsonify }}
      },
      "github": {
        "owner": {{ github_repo_owner | jsonify }},
        "name": {{ github_repo_name | jsonify }},
        "slug": {{ github_repo_slug | jsonify }},
        "url": {{ github_repo_base | jsonify }}
      },
      "author": {
        "name": {{ author_name | jsonify }},
        "url": {{ author_url | jsonify }},
        "github": {{ author_github | jsonify }},
        "github_url": {{ author_github_url | jsonify }},
        "email": {{ pkg.author_email | jsonify }}
      },
      "packager": {
        "name": {{ packager_name | jsonify }},
        "url": {{ packager_url | jsonify }},
        "github": {{ packager_github | jsonify }},
        "github_url": {{ packager_github_url | jsonify }}
      },
      {%- assign has_binary_value = pkg.has_binary -%}
      {%- if has_binary_value == nil or has_binary_value == "" or has_binary_value == false or has_binary_value == "false" -%}
        {%- assign has_binary = false -%}
      {%- else -%}
        {%- assign has_binary = true -%}
      {%- endif -%}
      "flags": {
        "unsafe": {{ pkg.unsafe | default: false | jsonify }},
        "excluded_in_search": {{ pkg.excluded_in_search | default: false | jsonify }},
        "has_binary": {{ has_binary | jsonify }}
      }
    }
    {%- endunless -%}
  {%- endif -%}
{%- endfor -%}
  ]
}
