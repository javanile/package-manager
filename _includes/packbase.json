{% include packages-assign.html %}
{
  "protocol": "v1",
  "packages": {
    "package": [
{% assign _first = true %}{% for pkg in packages %}{% if pkg.title %}{% unless pkg.excluded_in_search or pkg.unsafe %}{% unless _first %},
{% endunless %}{% assign _first = false %}      {
        "title": {{ pkg.title | jsonify }},
        "description": {{ pkg.description | jsonify }},
        "url": {{ pkg.url | jsonify }},
        "keywords": {{ pkg.keywords | jsonify }},
        "categories": {{ pkg.categories | jsonify }}
      }{% endunless %}{% endif %}{% endfor %}
    ]
  }
}
